## Google
GOOGLE_PLACES_API_KEY=

## Gmail API sender (OAuth)
# The mailbox that will send the admin notification (must match the OAuth consent/account).
GMAIL_SENDER_EMAIL=you@gmail.com

# If you want automatic refresh (recommended), set these:
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Optional: you can also provide a short-lived access token (not recommended for dev).
GMAIL_OAUTH_ACCESS_TOKEN=

